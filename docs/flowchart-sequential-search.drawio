        <mxCell id="legend-box" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;fontStyle=0;fontSize=10;" value="&lt;b&gt;KETERANGAN:&lt;/b&gt;&lt;br&gt;Hijau = Start/End&lt;br&gt;Biru = Proses Data&lt;br&gt;Kuning = Input/Output&lt;br&gt;Ungu = Filter/Pagination&lt;br&gt;Merah Muda = Algoritma Utama&lt;br&gt;Orange = Decision/Kondisi" vertex="1">
